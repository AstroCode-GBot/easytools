export default async function handler(req, res) {
  const { track } = req.query;

  if (!track) {
    return res.status(400).json({ error: "No track provided" });
  }

  // সার্ভার হিসেবে 'serv' ব্যবহার
  const apiUrl = `https://api.paxsenix.org/dl/spotify?url=${encodeURIComponent(track)}&serv=spotify`;

  try {
    const response = await fetch(apiUrl, {
      headers: {
        "Authorization": "Bearer sk-paxsenix-uWeVy8FnOtAQ9SDwyZYmGNQrY1y2ifGpL3XFTFDgSkrnON_b",
        "User-Agent": "Mozilla/5.0"
      }
    });

    const data = await response.json();
    res.status(200).json(data);

  } catch (err) {
    res.status(500).json({ error: "Fetch failed", details: err.message });
  }
}
